# Copy this file to .env and fill in your real values
# NEVER commit .env to GitHub

PORT=5000

# MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/alphametrics?retryWrites=true&w=majority

# JWT secret — use a strong random string
# Generate one: openssl rand -hex 32
JWT_SECRET=replace_with_a_long_random_secret

# Your Vercel frontend URL (set this on Render/Railway)
# Example: https://alphametrics.vercel.app
FRONTEND_URL=https://your-app.vercel.app
